# ============================================================
# AGENTE
# ============================================================
AGENT_NAME=agente_telegram_ponentes
APP_ENV=local
TIMEZONE=Europe/Madrid
MODO_DEMO=True
ORQUESTADOR_ENABLED=False

# ============================================================
# MODELO LLM - configurable por equipo
# ============================================================
LLM_PROVIDER=groq
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.1-8b-instant
# LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=1200
LLM_TIMEOUT_SECONDS=30

# ============================================================
# TELEGRAM
# ============================================================
TELEGRAM_ENABLED=False
TELEGRAM_BOT_TOKEN=
TELEGRAM_POLLING_TIMEOUT=5
TELEGRAM_REQUEST_TIMEOUT=15
TELEGRAM_CHECK_SECONDS=15

# Activar solo cuando se quiera responder realmente por Telegram.
ALLOW_SEND_TELEGRAM=False

# ============================================================
# BACKEND MITUMI
# ============================================================
# En pruebas locales se deja en False y se usan data/mock/*.json.
BACKEND_ENABLED=False
BACKEND_BASE_URL=http://localhost:8000
BACKEND_API_KEY=
BACKEND_TIMEOUT_SECONDS=15

# ============================================================
# SERVICIO LOCAL / HORARIO
# ============================================================
ORDINARY_START_HOUR=7
ORDINARY_END_HOUR=23
SERVICE_LOOP_SECONDS=2
QUIET_MODE_ENABLED=True
ALLOW_OUT_OF_HOURS_LOGGING=True

# ============================================================
# PERMISOS DEL AGENTE
# ============================================================
ALLOW_BACKEND_READ=True
ALLOW_BACKEND_WRITE=False
ALLOW_REGISTER_COMMUNICATION=True
ALLOW_CREATE_INCIDENTS=True
ALLOW_NOTIFY_ADMIN=True

# Seguridad: acciones críticas no automáticas.
ALLOW_CONFIRM_TRAVEL=False
ALLOW_APPROVE_DOCUMENTS=False
ALLOW_CHANGE_EVENT_DATA=False
ALLOW_MASS_MESSAGES=False
ALLOW_AUTO_APPROVAL=False
ALLOW_DB_WRITE=False
ALLOW_EXTERNAL_SEND=False
ALLOW_CREATE_EVENT=False

# ============================================================
# ADMIN / ESCALADO HUMANO
# ============================================================
ADMIN_TELEGRAM_CHAT_ID=
ADMIN_EMAIL=
ESCALATE_UNKNOWN_SPEAKER=True
ESCALATE_MULTIPLE_ACTIVE_EVENTS=True
ESCALATE_MISSING_DATA=True
ESCALATE_LOW_CONFIDENCE=True
MIN_CONFIDENCE_TO_REPLY=0.75

# ============================================================
# RAG LOCAL
# ============================================================
RAG_ENABLED=False
RAG_RESULTS=3
RAG_MIN_SIMILARITY=0.20

# ============================================================
# RUTAS / LOGS
# ============================================================
DATA_DIR=data
RAG_DIR=data/rag
OUTPUTS_DIR=outputs
LOG_DIR=logs
LOG_LEVEL=INFO
SHOW_STEPS=True
SAVE_CONVERSATION_LOG=True
