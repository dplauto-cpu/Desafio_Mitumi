# Copia este archivo a .env y rellena lo que necesites.
# .env NO se sube al repositorio (contiene secretos reales).
# .env.example SÍ se sube — es la plantilla sin secretos.

# --- Motor de extracción ---
# "reglas" (gratis, por defecto) o "llm" (Groq, requiere GROQ_API_KEY)
OPERIS_MOTOR=reglas

# --- LLM (Groq) — solo necesario si OPERIS_MOTOR=llm ---
# Clave gratuita en https://console.groq.com
GROQ_API_KEY=
# Modelo por defecto: openai/gpt-oss-120b (free tier: 1000 peticiones/día,
# 200.000 tokens/día — ver docs/estimacion_tokens.py para el detalle)
GROQ_MODEL=openai/gpt-oss-120b
