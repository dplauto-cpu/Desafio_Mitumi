# Este archivo contiene secretos reales - NO se sube al repositorio (ver .gitignore).
# Plantilla sin secretos: .env.example

MODO_DEMO=True
ENVIRONMENT=local

# LLM (Groq, API compatible con OpenAI)
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=800
GROQ_API_KEY=********************************************
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Permisos del agente - NO NEGOCIABLES para Lumen (se fuerzan ademas en config/permisos.py)
ALLOW_DB_WRITE=False
ALLOW_EXTERNAL_SEND=False
ALLOW_CREATE_EVENT=False
ALLOW_AUTO_APPROVAL=False

# Backend / BD - usuario de solo lectura
DATABASE_URL=
DATABASE_ROLE=readonly

# API real "Proyecto Tripulaciones" (ERP de Eventos, ver openapi.yaml) - GET de solo lectura.
# Cubre hoy eventos/clientes/espacios/ponentes. Salas, presupuestos, estados y ponencias no
# tienen endpoint todavia y siguen leyendose de data/mock/*.json (modo hibrido).
USAR_API_TRIPULACIONES=False
BACKEND_BASE_URL=http://localhost:3000/api/v1
# Token de servicio (JWT) ya emitido por POST /auth/login - pendiente de definir la cuenta de
# servicio con el equipo de backend. Poner_token_real_aqui es solo un placeholder.
API_TRIPULACIONES_TOKEN=poner_token_real_aqui

# Tablas excluidas explicitamente (defensa en profundidad)
TABLAS_EXCLUIDAS=usuarios

# Rutas locales
DATA_DIR=data
RAG_DIR=data/rag
OUTPUTS_DIR=outputs
LOG_LEVEL=INFO
